{
  "name": "noted-terminal",
  "version": "1.0.0",
  "description": "Terminal with tabs and notes",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:d": "cd design-lab && npm run dev",
    "build": "electron-vite build && electron-builder",
    "build:install": "pkill -f 'Noted Terminal' || true && electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder && rm -rf /Applications/Noted\\ Terminal.app && cp -R release/mac-arm64/Noted\\ Terminal.app /Applications/ && open /Applications/Noted\\ Terminal.app",
    "build:i": "npm run build:install",
    "_rebuild": "electron-rebuild -f -w node-pty",
    "_test:e2e": "cd runtime-tests && npx playwright test",
    "_test:e2e:headed": "cd runtime-tests && npx playwright test --headed",
    "index": "bash scripts/ai/build-index.sh",
    "index:force": "bash scripts/ai/build-index.sh --force"
  },
  "build": {
    "appId": "com.noted.terminal",
    "productName": "Noted Terminal",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build-resources/icon.icns",
      "target": "dir"
    },
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json",
      "!logs/**"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.59",
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.7",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.5",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@google/genai": "^1.38.0",
    "@gt-editor/markdown-editor": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.6.2",
    "debug": "^4.4.3",
    "framer-motion": "^12.27.5",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.562.0",
    "node-pty": "^1.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-grab": "^0.1.29",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-virtuoso": "^4.18.1",
    "remark-gfm": "^4.0.1",
    "virtua": "^0.48.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/debug": "^4.1.12",
    "@vitejs/plugin-react": "^5.1.2",
    "@xterm/headless": "^6.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  }
}
