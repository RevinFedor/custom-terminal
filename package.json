{
  "name": "noted-terminal",
  "version": "1.0.0",
  "description": "Terminal with tabs and notes",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:install": "electron-vite build && electron-builder && rm -rf /Applications/Noted\\ Terminal.app && cp -R release/mac-arm64/Noted\\ Terminal.app /Applications/",
    "rebuild": "electron-rebuild -f -w node-pty",
    "test:e2e": "cd runtime-tests && npx playwright test",
    "test:e2e:headed": "cd runtime-tests && npx playwright test --headed"
  },
  "build": {
    "appId": "com.noted.terminal",
    "productName": "Noted Terminal",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build-resources/icon.icns",
      "target": "dir"
    },
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    }
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.7",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@google/genai": "^1.38.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.6.2",
    "framer-motion": "^12.27.5",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.562.0",
    "node-pty": "^1.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-grab": "^0.0.98",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-virtuoso": "^4.18.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/cli": "^4.1.18",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  }
}
