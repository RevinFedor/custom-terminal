{
  "name": "noted-terminal",
  "version": "1.0.0",
  "description": "Terminal with tabs and notes",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development nodemon --exec 'npm run build:css && electron .' --watch main.js --watch project-manager.js --watch renderer.js --watch input.css --watch index.html",
    "build:css": "tailwindcss -i input.css -o output.css",
    "rebuild": "electron-rebuild -f -w node-pty",
    "build": "electron-builder",
    "dist": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.noted.terminal",
    "productName": "Noted Terminal",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build-resources/icon.icns",
      "target": "dir"
    },
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@tailwindcss/cli": "^4.1.18",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "nodemon": "^3.1.11",
    "tailwindcss": "^4.1.18"
  }
}
